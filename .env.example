# ---------------------------------------------------------------------------
# Supabase connection — copy this file to `.env.local` and fill in real values.
# Find these in your Supabase dashboard: Project Settings → API.
#
# Both keys below are SAFE to expose to the browser (the anon key is protected
# by Row Level Security). Never put the `service_role` key in a NEXT_PUBLIC_*
# variable. Do NOT commit your real `.env.local` file.
# ---------------------------------------------------------------------------

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your project's public anon key (a long JWT string).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
